{
  "expo": {
    "name": "NOW! Timer",
    "slug": "now-timer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nowtimer.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nowtimer.app"
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "00f246df-795e-4f4a-9453-c4d642f09dee"
      }
    },
    "owner": "nova_lab"
  }
}
